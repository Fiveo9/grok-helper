# Grok Register Service Environment Example
#
# Usage:
# 1. Copy to .env and modify as needed
# 2. Start with: docker compose up -d --build

# ==================== Basic ====================
TZ=Asia/Shanghai
LOG_LEVEL=INFO
LOG_FILE_ENABLED=true

# ==================== Server ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=8001

# ==================== Admin Auth ====================
# Required for /admin/register and /admin/register/* APIs
GROK_HELPER_ADMIN_USERNAME=admin
GROK_HELPER_ADMIN_PASSWORD=change-this-password

# ==================== Data & Logs ====================
DATA_DIR=/app/data
LOG_DIR=/app/logs

# ==================== Register Service ====================
# Max concurrent registration tasks
GROK_REGISTER_CONSOLE_MAX_CONCURRENT_TASKS=1
# Task polling interval (seconds)
GROK_REGISTER_CONSOLE_POLL_INTERVAL=2

# ==================== Default Registration Config ====================
# Default number of accounts to register per task
GROK_REGISTER_DEFAULT_RUN_COUNT=50

# Proxy for API requests (socks5/http)
GROK_REGISTER_DEFAULT_PROXY=
# Proxy for browser automation
GROK_REGISTER_DEFAULT_BROWSER_PROXY=

# ==================== Temporary Email Service ====================
# Provider: cloudmail / duckmail / mailtm (leave empty for auto-detect)
GROK_REGISTER_DEFAULT_TEMP_MAIL_PROVIDER=
# Email API base URL
GROK_REGISTER_DEFAULT_TEMP_MAIL_API_BASE=
# Admin email for email service
GROK_REGISTER_DEFAULT_TEMP_MAIL_ADMIN_EMAIL=
# Admin password for email service
GROK_REGISTER_DEFAULT_TEMP_MAIL_ADMIN_PASSWORD=
# Email domain(s), comma-separated for multiple domains
GROK_REGISTER_DEFAULT_TEMP_MAIL_DOMAIN=
# Site password (if required)
GROK_REGISTER_DEFAULT_TEMP_MAIL_SITE_PASSWORD=

# ==================== API Push ====================
# Where to push registered SSO tokens
GROK_REGISTER_DEFAULT_API_ENDPOINT=http://grok2api:8000/admin/api/tokens
# API authentication token
GROK_REGISTER_DEFAULT_API_TOKEN=
# Append mode (true) or replace mode (false)
GROK_REGISTER_DEFAULT_API_APPEND=true
